# Use a long random value in production (for example: openssl rand -base64 32)
ADMIN_PASSWORD=change-this-before-deploying
SESSION_SECRET=replace-with-a-long-random-string

# Create a free Redis database at https://upstash.com and copy its REST values.
# This is where the reset date and incident note are stored.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: gives the counter a start date before the first incident is logged.
# INITIAL_BROKEN_AT=2026-07-01T12:00:00.000Z
